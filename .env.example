# Backend
DATABASE_URL=postgresql+asyncpg://telemetry:telemetry@localhost:5432/telemetry_hub
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_ORIGIN=http://localhost:5173
LOG_LEVEL=info
SIMULATOR_TARGET_URL=http://localhost:8000

# Anomaly detection thresholds (tunable)
LOW_BATTERY_THRESHOLD_PCT=15
OVERSPEED_THRESHOLD_MPS=5.0
STALE_TELEMETRY_MAX_AGE_SECONDS=300

# Test database (used by pytest; created automatically if missing)
TEST_DATABASE_URL=postgresql+asyncpg://telemetry:telemetry@localhost:5432/telemetry_hub_test

# PostgreSQL container (local development only, not for production)
POSTGRES_USER=telemetry
POSTGRES_PASSWORD=telemetry
POSTGRES_DB=telemetry_hub

# Docker Compose host port mappings (change if a port is already in use)
POSTGRES_HOST_PORT=5432
BACKEND_HOST_PORT=8000
FRONTEND_HOST_PORT=5173

# Frontend
VITE_API_BASE_URL=http://localhost:8000
